# ═══════════════════════════════════════════════════════════
#  InvestIQ — Variables de entorno COMPLETAS
#  Copiar a .env y rellenar con valores reales
# ═══════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────
SECRET_KEY=investiq-prod-secret-CAMBIAR-2026
ENVIRONMENT=production
APP_VERSION=investiq@1.0.0
APP_URL=https://tu-dominio.com

# ── Base de datos ─────────────────────────────────────────
# Desarrollo (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./investiq.db
DATABASE_URL_SYNC=sqlite:///./investiq.db

# Producción (PostgreSQL + TimescaleDB):
# DATABASE_URL=postgresql+asyncpg://investiq:PASSWORD@localhost:5432/investiq
# DATABASE_URL_SYNC=postgresql://investiq:PASSWORD@localhost:5432/investiq

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Con auth: redis://:PASSWORD@localhost:6379/0

# ── Broker activo ─────────────────────────────────────────
# "alpaca"  → Paper trading gratuito (default, sin cuenta real)
# "ibkr"    → Interactive Brokers real (requiere Gateway corriendo local)
BROKER=alpaca

# ── Alpaca Paper Trading (GRATIS) ─────────────────────────
# 1. Crear cuenta: https://app.alpaca.markets/signup
# 2. Ir a Paper Trading → API Keys → Generate New Key
ALPACA_API_KEY=DEMO_KEY
ALPACA_API_SECRET=DEMO_SECRET

# ── Interactive Brokers — Trading Real desde Perú ─────────
# Prerequisitos:
#   1. Abrir cuenta en interactivebrokers.com (acepta Perú)
#   2. Descargar Client Portal Gateway:
#      https://www.interactivebrokers.com/en/trading/ib-api.php
#   3. Ejecutar: java -jar root/run.jar root/conf.yaml
#   4. Abrir https://localhost:5000 en el navegador y hacer login
#   5. Tu Account ID lo ves en la app IBKR (empieza con "U")
# Una vez listo, cambiar BROKER=ibkr arriba
IBKR_GATEWAY_URL=https://localhost:5000
IBKR_ACCOUNT_ID=U0000000

# ── Claude API — Robo-Advisor ─────────────────────────────
# https://console.anthropic.com → API Keys → Create Key
CLAUDE_API_KEY=

# ── Stripe — Pagos con tarjeta ────────────────────────────
# https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
# https://dashboard.stripe.com → Webhooks → Add endpoint
# URL: https://tu-dominio.com/api/v1/pagos/stripe/webhook
# Eventos: payment_intent.succeeded, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_

# ── MercadoPago — Pagos LATAM ────────────────────────────
# https://www.mercadopago.com.pe/developers → Credenciales → Producción
MERCADOPAGO_ACCESS_TOKEN=APP_USR-

# ── Coinbase Commerce — Crypto ────────────────────────────
# https://commerce.coinbase.com → Settings → API Keys
COINBASE_COMMERCE_KEY=

# ── Sentry — Monitoreo de errores ────────────────────────
# https://sentry.io → New Project → FastAPI
# Tier gratis: 5,000 errores/mes
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=
SENTRY_ORG=tu-org
SENTRY_PROJECT=investiq

# ── Email — SendGrid ──────────────────────────────────────
# https://sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.
FROM_EMAIL=noreply@investiq.co

# ── Push Notifications — VAPID ────────────────────────────
# Generar: GET /api/v1/admin/push/vapid/generar
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@investiq.co

# ── Backups ───────────────────────────────────────────────
BACKUP_DIR=./backups
BACKUP_RETAIN_DAYS=30
# S3 (opcional para backup remoto):
# BACKUP_S3_BUCKET=mi-bucket-investiq
# BACKUP_S3_PREFIX=backups/
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
BACKUP_NOTIFY_EMAIL=admin@investiq.co

# ── Exportes ──────────────────────────────────────────────
EXPORT_DIR=./static/exports

# ─────────────────────────────────────────────────────────
# RESUMEN DE COSTOS MENSUALES (aproximado)
# ─────────────────────────────────────────────────────────
# Railway (backend)        → $5/mes
# PostgreSQL (Railway)     → $5/mes
# Redis (Upstash free)     → $0
# Alpaca Paper Trading     → $0 (gratis)
# Claude API               → $1-10/mes (pay-per-use)
# Stripe                   → 2.9% + $0.30/tx
# MercadoPago              → 3.99%/tx
# Sentry (free tier)       → $0
# SendGrid (free tier)     → $0 (100 emails/día)
# Vercel (frontend)        → $0
# Dominio                  → ~$12/año
# ─────────────────────────────────────────────────────────
# TOTAL BASE               → ~$10-20/mes
