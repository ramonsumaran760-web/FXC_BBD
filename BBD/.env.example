# InvestIQ — Variables de entorno
# Copiar a .env y completar con valores reales

# ── Seguridad ─────────────────────────────────────────────
SECRET_KEY=investiq-prod-secret-CAMBIAR-EN-PRODUCCION-2026
JWT_SECRET=jwt-investiq-secret-CAMBIAR

# ── Base de datos ─────────────────────────────────────────
# SQLite (desarrollo):
DATABASE_URL=sqlite+aiosqlite:///./investiq.db
DATABASE_URL_SYNC=sqlite:///./investiq.db

# PostgreSQL + TimescaleDB (producción):
# DATABASE_URL=postgresql+asyncpg://investiq:PASSWORD@localhost:5432/investiq
# DATABASE_URL_SYNC=postgresql://investiq:PASSWORD@localhost:5432/investiq

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Con password: redis://:InvestIQRedis2026!@localhost:6379/0

# ── Alpaca Paper Trading (GRATIS en https://app.alpaca.markets) ──
ALPACA_API_KEY=DEMO_KEY
ALPACA_API_SECRET=DEMO_SECRET
# Con cuenta real paper:
# ALPACA_API_KEY=PK...
# ALPACA_API_SECRET=...

# ── Claude API — Robo-Advisor ─────────────────────────────
CLAUDE_API_KEY=
# Con key real: sk-ant-...

# ── App ───────────────────────────────────────────────────
DEBUG=false
EXPORT_DIR=./static/exports
