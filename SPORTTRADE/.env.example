# ═══════════════════════════════════════════════════════════════════════════════
# FXC_BBD — Financial Exchange Center BBD
# Variables de entorno — copiar a .env y rellenar
# ═══════════════════════════════════════════════════════════════════════════════

# ─── APP ─────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8001
DEBUG=false
SECRET_KEY=cambia-esto-por-un-secreto-largo-aleatorio-256bits

# CORS (separado por comas)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# SQLite (desarrollo)
DATABASE_URL=sqlite+aiosqlite:///./sporttrade.db

# PostgreSQL (producción)
# DATABASE_URL=postgresql+asyncpg://usuario:password@localhost:5432/fxcbbd

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1

# ─── ODDS STREAM (Brecha D) ──────────────────────────────────────────────────
# URL WebSocket del proveedor de odds en tiempo real
ODDS_WS_URL=wss://tu-proveedor-odds.com/stream
ODDS_API_KEY=tu-api-key-del-proveedor

# Latencia SLA — alerta si >500ms en >5% de updates
LATENCY_SLA_MS=500

# ─── KELLY CRITERION (Brecha A) ───────────────────────────────────────────────
KELLY_DEFAULT_DIVISOR=2.0
MAX_EXPOSICION_EVENTO=0.08
MAX_EXPOSICION_TOTAL=0.25

# ─── CIRCUIT BREAKER ─────────────────────────────────────────────────────────
# % de variación de cuota que activa el circuit breaker
CB_VARIACION_MAXIMA=0.20
# Segundos en estado OPEN antes de pasar a RECOVERING
CB_TIMEOUT_S=60

# ─── MONTE CARLO (Agente 8) ───────────────────────────────────────────────────
MC_ITERACIONES_LIVE=10000
MC_ITERACIONES_PREVIEW=50000
# Target: <50ms por partido en modo live
MC_TIMEOUT_MS=50

# ─── DATOS DEPORTIVOS ────────────────────────────────────────────────────────
# football-data.org
FOOTBALL_DATA_API_KEY=tu-api-key

# Odds API (The Odds API)
ODDS_API_URL=https://api.the-odds-api.com/v4
THE_ODDS_API_KEY=tu-api-key

# OpenWeatherMap (Agente 6 — clima)
OPENWEATHER_API_KEY=tu-api-key

# ─── NLP / IA (Agente 4 — Noticias) ─────────────────────────────────────────
# Hugging Face (modelos de sentimiento)
HF_TOKEN=hf_tu-token-de-huggingface

# OpenAI (opcional — para enriquecimiento de análisis de noticias)
OPENAI_API_KEY=sk-tu-api-key

# ─── MONITOREO ────────────────────────────────────────────────────────────────
# Sentry (error tracking en producción)
SENTRY_DSN=https://tu-dsn@sentry.io/tu-proyecto

# Prometheus scrape endpoint (interno)
PROMETHEUS_PORT=9090

# ─── CELERY ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# ─── INTEGRACIÓN InvestIQ (BBD4) ─────────────────────────────────────────────
# Base URL del backend InvestIQ para autenticación compartida de usuarios
INVESTIQ_API_URL=http://localhost:8000
INVESTIQ_JWT_SECRET=mismo-secret-que-investiq
